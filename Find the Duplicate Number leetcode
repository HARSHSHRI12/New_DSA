class Solution {
public:
    int findDuplicate(vector<int>& nums) {
        int slow=nums[0];
        int fast=nums[0];
        do{
            slow=nums[slow]; //increase by +1
            fast=nums[nums[fast]]; //increase by +1
        }
        while(slow!=fast);
        slow=nums[0];
        while(slow!=fast){
            slow=nums[slow]; //+1
            fast=nums[fast]; //+1
        }
        return slow;
    }
};
